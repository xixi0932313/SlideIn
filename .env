# 大模型：DeepSeek（默认）
# 在 https://platform.deepseek.com 获取 API Key
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_API_KEY=sk-3d809d4463cc46e8abeed91198b795ee

# 可选：若已使用 OPENAI_API_BASE / OPENAI_API_KEY，可不填上面两项，会自动兼容

# Optional: Web search (Tavily) - https://tavily.com
TAVILY_API_KEY=

# Optional: Image generation (Fal.ai) when not using OpenAI images - https://fal.ai
FAL_API_KEY=

# Whisper: "local" (faster-whisper, no key) or "openai" (Whisper API)
WHISPER_MODE=local

# Component toggles (true/false)
ENABLE_WEB_SEARCH=true
ENABLE_DOCUMENT_PARSE=true
ENABLE_PARSE_IMAGE=true
ENABLE_GENERATE_IMAGE=true
ENABLE_PARSE_VIDEO=true
ENABLE_ASR=true

# Output directory for exported PPT/Word
# SLIDEIN_OUTPUT_DIR=./output

# Open exported file with system default app (set false on headless servers)
OPEN_FILE_AFTER_EXPORT=true

# Web 服务：监听地址与端口（0.0.0.0 表示允许所有人通过本机 IP 访问）
# WEB_HOST=0.0.0.0
# WEB_PORT=8000
